.allure/
trace/
videos/
screenshots/
*.zip

# ── Local environment ─────────────────────────────────────────
.env
.env.local
.env.*.local

# ── IDE / OS ──────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

