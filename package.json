{
  "name": "brya-agentic-testing",
  "version": "1.0.0",
  "description": "Production-grade Playwright + TypeScript automation framework for brya.com — covering UI and API test layers with the Page Object Model, Allure reporting, and GitHub Actions CI.",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui-chromium --project=ui-firefox --project=ui-webkit",
    "test:ui:chromium": "playwright test --project=ui-chromium",
    "test:ui:firefox": "playwright test --project=ui-firefox",
    "test:ui:webkit": "playwright test --project=ui-webkit",
    "test:ui:mobile": "playwright test --project=ui-mobile",
    "test:api": "playwright test --project=api",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:headed": "playwright test --headed",
    "test:debug": "PWDEBUG=1 playwright test",
    "test:ui:single": "playwright test --project=ui-chromium",
    "report": "allure generate ./allure-results --clean -o ./allure-report && allure open ./allure-report",
    "report:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "report:open": "allure open ./allure-report",
    "report:clean": "rm -rf allure-results allure-report",
    "playwright:install": "playwright install --with-deps",
    "lint": "tsc --noEmit",
    "clean": "rm -rf allure-results allure-report test-results playwright-report"
  },
  "keywords": [
    "playwright",
    "typescript",
    "automation",
    "e2e",
    "api-testing",
    "page-object-model",
    "allure"
  ],
  "author": "Brya QA Engineering",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.0",
    "allure-commandline": "^2.30.0",
    "allure-playwright": "^3.0.0",
    "dotenv": "^16.4.5",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
