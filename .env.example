# ────────────────────────────────────────────────────────────────
# Brya Automation Framework — Environment Variables (Template)
# ────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in values for your environment.
# Never commit `.env` — it is in .gitignore.
# ────────────────────────────────────────────────────────────────

# Base URL of the application under test (no trailing slash).
# Override per environment: staging, prod, local.
BASE_URL=https://www.brya.com

# Base URL for API endpoints (often same host or an /api subpath).
API_BASE_URL=https://www.brya.com

# Default request timeout in milliseconds.
DEFAULT_TIMEOUT=30000

# Default navigation timeout in milliseconds.
NAVIGATION_TIMEOUT=45000

# Artificial delay (ms) before each browser action, so UI runs are easy to
# follow visually (best combined with HEADED=true). Set to 0 for full-speed CI.
SLOW_MO=500

# Number of test retries on failure (CI typically uses 2, local 0).
RETRIES=0

# Number of parallel workers. Leave blank to use Playwright defaults.
WORKERS=

# Whether to run browsers in headed mode for local debugging.
HEADED=false

# Optional: credentials for authenticated flows (not committed).
TEST_USER_EMAIL=
TEST_USER_PASSWORD=

# Environment tag attached to Allure reports.
TEST_ENV=production

# Opt-in gate for the live contact-form submission test. Leave unset/false so
# CI never sends a real inquiry to the Brya business team. Set to `true` only
# for deliberate, manual end-to-end verification.
SUBMIT_CONTACT_FORM=false
